          },
          "elements": [
            {
              "id": "c65fbyz",
              "elType": "widget",
              "widgetType": "html",
              "settings": {
                "html": "<div style=\"background:#F8FAFC;border-radius:12px;padding:40px;border-left:4px solid #08428C;\"><div style=\"display:grid;grid-template-columns:1fr 1fr;gap:32px;\"><div style=\"text-align:center;\"><div style=\"font-family:Inter,sans-serif;font-weight:800;font-size:36px;color:#08428C;line-height:1;\">2004</div><div style=\"font-family:Inter,sans-serif;font-size:13px;color:#475569;margin-top:6px;\">Año de fundación</div></div><div style=\"text-align:center;\"><div style=\"font-family:Inter,sans-serif;font-weight:800;font-size:36px;color:#08428C;line-height:1;\">3.000+</div><div style=\"font-family:Inter,sans-serif;font-size:13px;color:#475569;margin-top:6px;\">Clientes activos</div></div><div style=\"text-align:center;\"><div style=\"font-family:Inter,sans-serif;font-weight:800;font-size:36px;color:#08428C;line-height:1;\">50.000+</div><div style=\"font-family:Inter,sans-serif;font-size:13px;color:#475569;margin-top:6px;\">Referencias en stock</div></div><div style=\"text-align:center;\"><div style=\"font-family:Inter,sans-serif;font-weight:800;font-size:36px;color:#08428C;line-height:1;\">8</div><div style=\"font-family:Inter,sans-serif;font-size:13px;color:#475569;margin-top:6px;\">Marcas autorizadas</div></div></div></div>"
              },
